# Browser-facing Accounts API base URL.
# Recommended: same-origin proxy avoids browser CORS problems.
VITE_AUTH_API_BASE_URL=/accounts-api

# Direct API URL also works only when the accounts API CORS allows the website origin:
# VITE_AUTH_API_BASE_URL=https://accounts.aottg2.com

# Local standalone auth service examples:
# VITE_AUTH_API_BASE_URL=http://localhost:5000
# VITE_AUTH_API_BASE_URL=http://localhost:5010
