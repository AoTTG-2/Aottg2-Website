# Self-host / Docker Compose defaults.
# Browser-facing API path baked into the Vite build.
# Keep same-origin to avoid browser CORS.
VITE_AUTH_API_BASE_URL=/accounts-api

# Host port for docker compose.
WEB_PORT=8080

# Runtime nginx upstream for /accounts-api/*.
# No trailing slash. App calls /accounts-api/v1/*, proxy forwards to ${ACCOUNTS_API_UPSTREAM}/v1/*.
ACCOUNTS_API_UPSTREAM=https://accounts.aottg2.com

# Local auth service from Docker Desktop example:
# ACCOUNTS_API_UPSTREAM=http://host.docker.internal:5010
