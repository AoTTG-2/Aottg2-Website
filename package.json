{
  "name": "aottg2-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "deploy-local": "../AoTTG-2-auth-service/scripts/deploy-local.sh",
    "predev:local": "npm run deploy-local",
    "dev:local": "VITE_AUTH_API_BASE_URL=/accounts-api ACCOUNTS_API_UPSTREAM=http://localhost:${ACCOUNTS_API_PORT:-5010} vite --mode local-auth",
    "dev:prod": "VITE_AUTH_API_BASE_URL=/accounts-api ACCOUNTS_API_UPSTREAM=https://aottg2.com vite --mode prod-auth",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test:e2e:auth": "playwright test tests/playwright-auth-smoke.spec.ts --browser=chromium"
  },
  "dependencies": {
    "@aottg2/ui": "github:AoTTG-2/AoTTG2-component-library#4c08ae8178c4ef8e1c1f4c1e4cb426d4d022c1dc",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "framer-motion": "^10.16.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.3.0",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.4.31",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-image-optimizer": "^1.1.8",
    "vite-plugin-svgr": "^4.2.0"
  }
}
